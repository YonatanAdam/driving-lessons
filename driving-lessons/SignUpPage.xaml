<Page x:Class="driving_lessons.SignUpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:driving_lessons"
      mc:Ignorable="d" 
      d:DesignHeight="675" d:DesignWidth="1200"
      Title="SignUpPage">

    <Grid>
        <Border Background="#FF1E1E1E" 
                CornerRadius="10" 
                Width="340" 
                Padding="30"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center">
            <StackPanel Margin="15">
                <!-- Logo -->
                <!--<Image Width="120" Height="120" 
                       Source="assets/watchful-logo.png" 
                       Margin="0,0,0,20"/>-->

                <!-- Welcome Text -->
                <TextBlock Text="Create Account" 
                           Foreground="White" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <RadioButton Content="Student" Foreground="White"
                         GroupName="UserType" 
                         IsChecked="True"
                         Margin="0,0,5,0"
                         x:Name="StudentSignUp"
                         Checked="UserType_Checked"/>
                    <RadioButton Content="Teacher" Foreground="White"
                         GroupName="UserType" 
                         x:Name="TeacherSignUp"
                         Checked="UserType_Checked"/>
                </StackPanel>


                <!-- Username -->
                <TextBlock Text="Username" 
                           Foreground="#FFA0A0A0" 
                           FontSize="13" 
                           Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox"/>
                <!-- Password -->
                <TextBlock Text="Password" 
                           Foreground="#FFA0A0A0" 
                           FontSize="13" 
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" />

                <!-- Confirm Password -->
                <TextBlock Text="Confirm Password" 
                           Foreground="#FFA0A0A0" 
                           FontSize="13" 
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" />

                <StackPanel x:Name="StudentFields">
                    <TextBlock Text="Age" Foreground="#FFA0A0A0" FontSize="13" Margin="0,0,0,5"/>
                    <TextBox x:Name="AgeTextBox"/>
                </StackPanel>

                <!-- Sign Up Button -->
                <Button Content="Sign Up" 
                        Margin="0,20,0,0"
                        Click="SignUpButton_Click"/>

                <!-- Back to Login Link -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Margin="0,10,0,0">
                    <TextBlock Text="Already have an account? " 
                               Foreground="#FFA0A0A0" 
                               FontSize="13"/>
                    <TextBlock Text="Log In" 
                               Foreground="#FF007AFF" 
                               FontSize="13" 
                               Cursor="Hand"
                               MouseDown="BackToLoginButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
