<Page x:Class="driving_lessons.StudentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:driving_lessons"
      mc:Ignorable="d"
      Title="Student" Height="720" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Left Menu -->
        <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="#333" Padding="10">
                <StackPanel Orientation="Vertical">
                    <Button Content="Dashboard" Margin="0,5" Width="150" Click="DashboardButton_OnClick"/>
                    <Button Content="My Profile" Margin="0,5" Width="150" Click="MyProfileButton_OnClick"/>
                    <Button Content="Browse Teachers" Margin="0,5" Width="150" Click="BrowseTeachersButton_OnClick"/>
                    <Button Content="My Lessons" Margin="0,5" Width="150" Click="MyLessonsButton_OnClick"/>
                    <Button Content="My Progress" Margin="0,5" Width="150" Click="MyProgressButton_OnClick"/>
                    <Button Content="Logout" Margin="0,350,0,0"
                            Background="Red"
                            Foreground="White" Width="100"
                            Click="LogoutButton_OnClick"/>
                </StackPanel>
        </Border>
        
        <!-- Search/Filter Section -->
<!-- Search/Filter Section -->
<StackPanel x:Name="SearchPanel" Grid.Row="1" Grid.Column="1" Margin="10">

    <!-- Labels row -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Foreground="White" Text="Search" Grid.Column="0" HorizontalAlignment="Left" Margin="5"/>
        <TextBlock Foreground="White" Text="City" Grid.Column="1" HorizontalAlignment="Left" Margin="5"/>
        <TextBlock Foreground="White" Text="Transmission Type" Grid.Column="2" HorizontalAlignment="Left" Margin="5"/>
        <TextBlock Foreground="White" Text="Maximum Price" Grid.Column="3" HorizontalAlignment="Left" Margin="5"/>
    </Grid>

    <!-- Inputs row -->
    <Grid x:Name="FiltersGrid" Visibility="Collapsed">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="SearchTextBox" Text="" Grid.Column="0" Margin="5"/>
        
        <ComboBox x:Name="LocationFilter" Grid.Column="1" Margin="5">
            <ComboBoxItem Content="All Cities" IsSelected="True"/>
            <ComboBoxItem Content="Netanya"/>
            <ComboBoxItem Content="Tel-Aviv"/>
            <ComboBoxItem Content="Haifa"/>
            <ComboBoxItem Content="Jerusalem"/>
        </ComboBox>

        <ComboBox x:Name="TransmissionFilter" Grid.Column="2" Margin="5">
            <ComboBoxItem Content="Automatic" IsSelected="True"/>
            <ComboBoxItem Content="Manual"/>
            <ComboBoxItem Content="Both"/>
        </ComboBox>

        <TextBox x:Name="MaxPriceTextBox" Text="" Grid.Column="3" Margin="5"/>

        <Button Content="Clear Filters" Grid.Column="4" Click="ClearFilters_OnClick" Margin="5"/>
    </Grid>

</StackPanel>
        <!-- Teachers DataGrid -->
        <DataGrid x:Name="TeachersDataGrid"
                  Grid.Row="2" 
                  Grid.Column="1" 
                  Margin="10"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Visibility="Collapsed"
                  AlternatingRowBackground="LightGray"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="100"/>
                <DataGridTextColumn Header="Price" Binding="{Binding PricePerLesson}" Width="60"/>
                <DataGridTextColumn Header="Exp." Binding="{Binding YearsExperience}" Width="50"/>
                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="80"/>
                <DataGridTextColumn Header="Car" Binding="{Binding CarMake}" Width="70"/>
                <DataGridTextColumn Header="Trans." Binding="{Binding TransmissionType}" Width="70"/>
                <DataGridTextColumn Header="Rating" Binding="{Binding AverageRating}" Width="60"/>
        
                <DataGridTemplateColumn Header="Actions" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="View" Width="60" Margin="2" Click="ViewProfile_OnClick"/>
                                <Button Content="Book" Width="60" Margin="2" Background="LightGreen" Click="BookLesson_OnClick"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Dashboard Panel -->
<!-- Dashboard Panel -->
<StackPanel x:Name="DashboardPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Visibility="Collapsed">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

            <!-- Top row: two cards side by side -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Upcoming Lessons Card -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Upcoming Lessons" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Border Background="#EEF6FF" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Tomorrow, 3:00 PM" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Status: Confirmed" FontSize="12" Foreground="Green" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#EEF6FF" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Mar 15, 10:00 AM" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Status: Pending" FontSize="12" Foreground="Orange" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button Content="View All Lessons" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- My Progress Card -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="My Progress" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                        <TextBlock Text="Overall Completion" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <ProgressBar Height="18" Value="60" Maximum="100" Margin="0,0,0,4"/>
                        <TextBlock Text="60% Complete" FontSize="12" HorizontalAlignment="Right" Foreground="Gray" Margin="0,0,0,12"/>

                        <TextBlock Text="Recently Completed" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="✓ Basic Vehicle Controls" FontSize="12" Foreground="#2E7D32" Margin="0,2"/>
                        <TextBlock Text="✓ Mirror Adjustment" FontSize="12" Foreground="#2E7D32" Margin="0,2"/>
                        <TextBlock Text="✓ Starting and Stopping" FontSize="12" Foreground="#2E7D32" Margin="0,2"/>

                        <Button Content="View Full Progress" Margin="0,12,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</StackPanel>
        
        <!-- My Lessons Panel -->
        <StackPanel x:Name="MyLessonsPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Visibility="Collapsed">
            <!-- Lessons content -->
            <TextBlock Text="My Lessons!"/>
        </StackPanel>

        <!-- My Progress Panel -->
        <StackPanel x:Name="MyProgressPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Visibility="Collapsed">
            <!-- Progress content -->
            <TextBlock Text="My Progress!"/>
        </StackPanel>

        <ScrollViewer x:Name="MyProfilePanel" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto"
                      Margin="0,8,14,0" Visibility="Visible">
                <StackPanel>
                    <Border Background="White" CornerRadius="8" Padding="25" MaxWidth="600">
                        <StackPanel>
                            <TextBlock Text="Personal Information" FontSize="16" FontWeight="SemiBold" Foreground="#333333"
                                       Margin="0,0,0,20"/> 
                            <Separator Margin="0,0,0,20"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Full Name" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center"/>
                                <TextBox x:Name="ProfileNameTextBox"
                                         Grid.Column="1" FontSize="13" Padding="8,6" IsReadOnly="True" Background="#F9F9F9"
                                         BorderBrush="#DDDDDD" IsEnabled="False"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Email Address" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center"/>
                                <TextBox x:Name="EmailTextBox"
                                         Grid.Column="1" FontSize="13" Padding="8,6" IsReadOnly="True" Background="#F9F9F9"
                                         BorderBrush="#DDDDDD" IsEnabled="False"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Age" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center"/>
                                <TextBox x:Name="AgeTextBox"
                                         Grid.Column="1" FontSize="13" Padding="8,6" IsReadOnly="True" Background="#F9F9F9"
                                         BorderBrush="#DDDDDD" IsEnabled="False"/>
                            </Grid>
                            
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Assigned Teacher"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#555555"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="AssignedTeacherTextBox"
                                         Grid.Column="1"
                                         FontSize="13"
                                         Padding="8,6"
                                         IsReadOnly="True"
                                         IsEnabled="False"
                                         Background="#EFEFEF"
                                         Foreground="Black"
                                         BorderBrush="#DDDDDD"/>
                            </Grid>
                            
                            <Separator Margin="0,6,0,14"/>
                            
                            <Button x:Name="ChangePasswordToggleButton"
                                    Content="Change Password"
                                    HorizontalAlignment="Left"
                                    Width="150" Height="30"
                                    Margin="0,0,0,14"
                                    Click="ChangePasswordToggleButton_OnClick"/>
                                
                            <StackPanel x:Name="PasswordFieldsPanel" Visibility="Collapsed">

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Current Password"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#555555" VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="CurrentPasswordBox"
                                                 Grid.Column="1" FontSize="13" Padding="8,6"
                                                 BorderBrush="#DDDDDD"/>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="New Password"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#555555" VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="NewPasswordBox"
                                                 Grid.Column="1" FontSize="13" Padding="8,6"
                                                 BorderBrush="#DDDDDD"/>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Save New Password"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#555555" VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="ConfirmPasswordBox"
                                                 Grid.Column="1" FontSize="13" Padding="8,6"
                                                 BorderBrush="#DDDDDD"/>
                                </Grid>
                                
                                <Button Content="Save new password" Click="ConfirmChangePassword_OnClick"
                                        HorizontalAlignment="Right"
                                        Width="150" Height="30"
                                        Margin="0,0,0,14"/>

                            </StackPanel>
                            <Border x:Name="ProfileStatusBorder"
                                    CornerRadius="4"
                                    Padding="8,6"
                                    Margin="0,0,0,14"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="ProfileStatusLabel"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>
                            
                            <!--── Action Buttons ──-->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">

                                <Button x:Name="ProfileEditButton"
                                        Content="Edit Profile"
                                        Width="110" Height="34"
                                        Margin="0,0,8,0"
                                        Background="#2196F3"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Click="ProfileEditButton_OnClick"/>

                                <Button x:Name="ProfileCancelButton"
                                        Content="Cancel"
                                        Width="90" Height="34"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed"
                                        Click="ProfileCancelButton_OnClick"/>

                                <Button x:Name="ProfileSaveButton"
                                        Content="Save Changes"
                                        Width="120" Height="34"
                                        Visibility="Collapsed"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Click="ProfileSaveButton_OnClick"/>

                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>