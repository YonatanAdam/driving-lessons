<Page x:Class="driving_lessons.TeacherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:driving_lessons"
      mc:Ignorable="d"
      Title="Teacher" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- Display Teacher Info -->
        <StackPanel Grid.Column="0" Margin="20">
            <TextBlock Foreground="White" Text="Teacher Information" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
        
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Name: " Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="NameTextBlock" Foreground="White"/>
            </StackPanel>
        
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="ID: " FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="IdTextBlock" Foreground="White"/>
            </StackPanel>
        
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="User ID: " FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="UserIdTextBlock" Foreground="White"/>
            </StackPanel>
        
            <TextBlock Text="Bio: " FontWeight="Bold" Margin="0,10,0,5" Foreground="White"/>
            <TextBlock x:Name="BioTextBlock" TextWrapping="Wrap" Foreground="White"/>
        </StackPanel>
        
        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Update Bio" Margin="5" HorizontalAlignment="Center"/>
            <TextBox x:Name="BioTextBox" Margin="5" Width="200" Height="100"/>
            <Button Content="Update" Width="55" Margin="5" Height="20" Click="ButtonBase_OnClick"/>
        </StackPanel>
    </Grid>
</Page>
