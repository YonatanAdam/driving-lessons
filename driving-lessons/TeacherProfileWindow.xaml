<Window x:Class="driving_lessons.TeacherProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teacher Profile" Height="500" Width="450" 
        Background="#1A1C1E" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9BA3AF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="25">
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="32" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Bio}" Foreground="#BDC3C7" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>

                <UniformGrid Columns="2" Margin="0,0,0,20">
                    <Border Background="#2C3E50" Margin="0,0,5,0" Padding="15" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="EXPERIENCE" Style="{StaticResource LabelText}"/>
                            <TextBlock Text="{Binding YearsExperience, StringFormat={}{0} Years}" Style="{StaticResource ValueText}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2C3E50" Margin="5,0,0,0" Padding="15" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="RATE" Style="{StaticResource LabelText}"/>
                            <TextBlock Text="{Binding PricePerLesson, StringFormat=₪{0:N2}/hr}" Style="{StaticResource ValueText}" Foreground="#2ECC71"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Background="#2C3E50" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Vehicle" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,10"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding CarMake}" Style="{StaticResource ValueText}"/>
                            <TextBlock Text="{Binding CarModel}" Style="{StaticResource ValueText}" Margin="5,0"/>
                            <TextBlock Text="{Binding TransmissionType, StringFormat=({0})}" Foreground="#9BA3AF" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Location" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Location}" Style="{StaticResource ValueText}" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Languages" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,10"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Languages}" Style="{StaticResource ValueText}" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Reviews" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,10"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="★ " Foreground="#F1C40F" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AverageRating}" Style="{StaticResource ValueText}"/>
                            <TextBlock Text="{Binding TotalReviews, StringFormat=' ({0} reviews)'}" Foreground="#9BA3AF" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,20,0,0" Padding="10" CornerRadius="8" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAvailableForBooking}" Value="True">
                                    <Setter Property="Background" Value="#1E272E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#2ECC71" Margin="0,0,8,0"/>
                        <TextBlock Text="Available for new students" Foreground="#2ECC71" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>